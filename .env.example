# Copie ce fichier en .env et remplis tes clés.

# ─── Ollama Cloud (obligatoire) ──────────────────────────────────────────────
# https://ollama.com/settings/keys
OLLAMA_API_KEY=

# ─── Langfuse (optionnel — observabilité LLM) ────────────────────────────────
# Sign-up gratuit : https://cloud.langfuse.com (ou self-host)
# Si ces 3 vars sont vides, l'app marche pareil — pas de tracing, c'est tout.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
